[{"start": 0.0, "end": 3.0, "text": "Today Tani will enjoy in leisure."}, {"start": 4.0, "end": 5.0, "text": "Did you sleep, son?"}, {"start": 5.0, "end": 6.0, "text": ""}, {"start": 8.0, "end": 9.0, "text": "Did you take two pills?"}, {"start": 9.0, "end": 11.0, "text": "Ad also took medicine"}, {"start": 11.0, "end": 12.0, "text": "And sleep too"}, {"start": 13.0, "end": 14.0, "text": "Very well"}, {"start": 15.0, "end": 16.0, "text": "Ah"}, {"start": 17.0, "end": 19.0, "text": "What's being cooked here?"}, {"start": 19.0, "end": 20.0, "text": "Bring paneer"}, {"start": 20.0, "end": 21.0, "text": "What's the matter?"}, {"start": 21.0, "end": 51.0, "text": ""}, {"start": 51.0, "end": 53.0, "text": "She was appreciating"}, {"start": 53.0, "end": 55.0, "text": "She is taking yours"}, {"start": 55.0, "end": 57.0, "text": "You are good, aren't you?"}, {"start": 57.0, "end": 59.0, "text": "It was upgraded"}, {"start": 59.0, "end": 61.0, "text": "Not you to me"}, {"start": 61.0, "end": 63.0, "text": "You appear in both of them"}, {"start": 63.0, "end": 65.0, "text": "Remember"}, {"start": 65.0, "end": 67.0, "text": "How many of mine are you in the children?"}, {"start": 67.0, "end": 69.0, "text": "You in me in our children"}, {"start": 69.0, "end": 71.0, "text": "This is in front of our children"}, {"start": 71.0, "end": 73.0, "text": "This is in front of our children"}, {"start": 73.0, "end": 75.0, "text": "This is in front of the children"}, {"start": 75.0, "end": 77.0, "text": "This is in front of the children"}, {"start": 77.0, "end": 79.0, "text": "Since I saw, I haven't raised children"}, {"start": 79.0, "end": 81.0, "text": "In front of our children"}, {"start": 81.0, "end": 83.0, "text": "This is in front of our children"}, {"start": 83.0, "end": 85.0, "text": "This is in front of the children"}, {"start": 99.0, "end": 100.52, "text": "The furnace smells really bad."}, {"start": 102.28, "end": 105.16, "text": "And I don't care about my children either"}, {"start": 105.92, "end": 108.32, "text": "If for Kanko, mom's work is everything."}, {"start": 129.0, "end": 137.0, "text": "It's better than Ad, taking responsibility, leaving everything behind."}]